# Local development placeholders only.
# Do not put real production secrets in this file.

APP_DOMAIN="ops.example.com"
CF_TEAM_DOMAIN="example-team"
EMAIL_FROM="ops@example.com"
NOTIFY_EMAILS="operator@example.com"
GITHUB_REPO_OWNER="example-owner"
GITHUB_REPO_NAME="ops-dashboard"
SCHEDULER_TZ="America/New_York"

# Use `npx wrangler secret put NAME` for deployed Worker secrets.
# For local Wrangler development, use `.dev.vars` and keep it out of Git.
# For one-shot non-interactive Cloudflare provisioning, put these in an
# untracked `.setup.env` or CI secret store, not in committed files.
CLOUDFLARE_ACCOUNT_ID="replace-with-cloudflare-account-id"
CLOUDFLARE_API_TOKEN="replace-with-cloudflare-api-token"
OPS_SECRETS_MASTER_KEY="replace-with-local-random-value"
CF_ACCESS_AUD="replace-with-cloudflare-access-audience"
EMAIL_PROVIDER_API_KEY="replace-with-local-test-key"
GITHUB_APP_ID="replace-with-github-app-id"
GITHUB_INSTALLATION_ID="replace-with-github-installation-id"
GITHUB_APP_PRIVATE_KEY="replace-with-base64-encoded-private-key"
